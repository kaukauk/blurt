#!/usr/bin/env bash
# Tiny client: send a command to the running STT daemon.
#   stt-toggle start   -> begin recording   (bound to Alt+Space)
#   stt-toggle stop    -> stop & transcribe
#   stt-toggle toggle  -> flip (default)
# Stopping is normally done by pressing Space, handled inside the daemon.
CMD="${1:-toggle}"
SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/stt-daemon.sock"
if [ ! -S "$SOCK" ]; then
  notify-send -a linux-stt "STT daemon not running" "Run run-daemon.sh (or wait for autostart)" 2>/dev/null
  exit 1
fi
exec python3 -c "import socket,sys; s=socket.socket(socket.AF_UNIX); s.connect('$SOCK'); s.sendall(sys.argv[1].encode()); s.close()" "$CMD"
