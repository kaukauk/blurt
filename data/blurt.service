[Unit]
Description=blurt local dictation daemon
Documentation=https://github.com/kaukauk/blurt
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/blurt daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
WantedBy=default.target
